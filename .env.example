# ─── Required ────────────────────────────────────────────────
# Telegram Bot token (get from @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Gemini API key (https://aistudio.google.com/apikey)
GOOGLE_API_KEY=your_google_api_key

# ─── Security ────────────────────────────────────────────────
# Comma-separated Telegram user IDs allowed to use the bot.
# Leave empty to allow everyone (open mode).
ALLOWED_USER_IDS=

# ─── Optional ────────────────────────────────────────────────
# Secondary Gemini API key to distribute load across agents
GOOGLE_API_KEY_AGENTS=

# Todoist integration
TODOIST_API_TOKEN=

# Telethon scraper (https://my.telegram.org/apps)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_PHONE_NUMBER=

# Optional Gemini settings
# LLM_MODEL=gemini-2.5-flash
# MEMORY_PRUNE_THRESHOLD=20

# Rate limiting (defaults: 4.0s delay, 15 RPM — matches Gemini free tier)
RATE_LIMIT_DELAY=4.0
RATE_LIMIT_MAX_RPM=15
